{
  "name": "js9-modern",
  "version": "3.10.0-experimental.0",
  "description": "Modern fork of JS9 — astronomical FITS image display in the browser (WebAssembly engine, node build, static-first). Fork of ericmandel/js9.",
  "main": "_site/js9.min.js",
  "jsdelivr": "_site/js9.min.js",
  "unpkg": "_site/js9.min.js",
  "files": [
    "_site/js9.js",
    "_site/js9.min.js",
    "_site/js9.css",
    "_site/js9support.js",
    "_site/js9support.min.js",
    "_site/js9support.css",
    "_site/js9support.txt",
    "_site/js9plugins.js",
    "_site/js9plugins.min.js",
    "_site/js9-allinone.js",
    "_site/js9-allinone.css",
    "_site/js9prefs.js",
    "_site/js9Prefs.json",
    "_site/js9worker.js",
    "_site/js9PostMessage.js",
    "_site/astroem.js",
    "_site/astroemw.js",
    "_site/astroemw.wasm",
    "_site/images/toolbar",
    "_site/images/js9logo/png",
    "_site/images/js9logo.png",
    "_site/images/js9-apple-touch-icon.png",
    "_site/images/*.gif",
    "_site/images/*.svg",
    "_site/images/gears.png",
    "_site/images/sun.png",
    "_site/images/4arrow.png",
    "_site/images/indentbg*.png",
    "_site/font",
    "_site/params"
  ],
  "scripts": {
    "start": "build/quicktest",
    "test": "playwright test",
    "test:quick": "build/quicktest build/i800400.fits.gz",
    "typecheck": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "build": "node scripts/build.mjs && npm run docs && npm run search",
    "docs": "eleventy",
    "search": "pagefind --site _site",
    "serve": "npm run build && eleventy --serve"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sarhatabaot/js9.git"
  },
  "keywords": [
    "astronomy",
    "fits",
    "image display",
    "visualization",
    "wasm",
    "webassembly",
    "ds9",
    "js9"
  ],
  "author": "Omer Oreg (https://sarhatabaot.net)",
  "contributors": [
    "Eric Mandel (Center for Astrophysics | Harvard & Smithsonian) — original author, JS9 through v3.9",
    "Alexey Vikhlinin (Center for Astrophysics | Harvard & Smithsonian) — original author"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sarhatabaot/js9/issues"
  },
  "homepage": "https://sarhatabaot.net/js9/",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "minimist": "^1.2.7",
    "open": "^8.2.1",
    "pagefind": "^1.5.2",
    "ps-list": "^7.2.0",
    "rimraf": "^3.0.2",
    "socket.io": "^4.5.4",
    "socket.io-client": "^4.5.4",
    "typescript": "^6.0.3",
    "uuid": "^9.0.0"
  }
}
