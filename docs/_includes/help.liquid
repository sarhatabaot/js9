<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<script>
  /* set the saved theme before paint (no flash of the wrong theme) */
  (function(){ try {
    var t = localStorage.getItem("js9-theme");
    if (t === "light" || t === "dark") document.documentElement.setAttribute("data-theme", t);
  } catch(e){} })();
</script>
<link rel="stylesheet" href="{{ prefix }}js9.css">
<link rel="stylesheet" href="{{ prefix }}vendor/highlight.css">
<link rel="stylesheet" href="{{ prefix }}pagefind/pagefind-component-ui.css">
<title>{{ title }} &middot; JS9 Docs</title>
{% if head %}{{ head }}{% endif %}
<style>
  /* light theme (default) */
  :root { --bg:#fff; --fg:#1a202c; --muted:#5a6675; --border:#e2e8f0;
    --hover:#f7fafc; --active-bg:#ebf4ff; --accent:#2b6cb0; --code-bg:#0d1117; }
  /* dark: when the system prefers dark and the user has not forced light... */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) { --bg:#0d1117; --fg:#e6edf3; --muted:#8b98a5;
      --border:#30363d; --hover:#161b22; --active-bg:#1f2b3a; --accent:#58a6ff; --code-bg:#010409; }
  }
  /* ...or when the user explicitly picks dark */
  :root[data-theme="dark"] { --bg:#0d1117; --fg:#e6edf3; --muted:#8b98a5;
    --border:#30363d; --hover:#161b22; --active-bg:#1f2b3a; --accent:#58a6ff; --code-bg:#010409; }

  * { box-sizing: border-box; }
  body { margin:0; background:var(--bg); color:var(--fg);
    font:15px/1.65 -apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif; }
  a { color: var(--accent); }
  .docsHeader { position:sticky; top:0; z-index:20; display:flex; align-items:center;
    gap:14px; padding:8px 16px; background:var(--bg); border-bottom:1px solid var(--border); }
  .docsBrand { display:flex; align-items:center; gap:8px; text-decoration:none;
    color:var(--fg); font-weight:600; white-space:nowrap; }
  .docsBrand img { height:26px; }
  .docsHeader pagefind-modal-trigger { flex:1; max-width:360px; }
  .searchBtn { width:100%; text-align:left; padding:7px 12px; border-radius:8px;
    border:1px solid var(--border); background:var(--hover); color:var(--muted);
    font:inherit; font-size:14px; cursor:pointer; }
  .searchBtn:hover { border-color:var(--accent); }
  .iconBtn { margin-left:auto; background:none; border:1px solid var(--border);
    border-radius:8px; width:34px; height:34px; font-size:16px; cursor:pointer; color:var(--fg); }
  .iconBtn:hover { border-color:var(--accent); }
  .docsGh { text-decoration:none; color:var(--accent); font-size:14px; }
  .docsLayout { display:flex; align-items:flex-start; }
  .docsSidebar { width:264px; flex:0 0 264px; position:sticky; top:44px;
    height:calc(100vh - 44px); overflow-y:auto; padding:18px 14px; border-right:1px solid var(--border); }
  .docsSection { margin-bottom:18px; }
  .docsSectionTitle { font-size:11px; text-transform:uppercase; letter-spacing:.06em;
    color:var(--muted); margin:0 8px 6px; }
  .docsSidebar ul { list-style:none; margin:0; padding:0; }
  .docsSidebar li a { display:block; padding:4px 8px; border-radius:5px;
    text-decoration:none; color:var(--fg); font-size:14px; }
  .docsSidebar li a:hover { background:var(--hover); }
  .docsSidebar li a.active { background:var(--active-bg); color:var(--accent); font-weight:600; }
  .docsContent { flex:1 1 auto; min-width:0; padding:20px 36px 40px; max-width:920px; color:var(--fg); }
  .docsContent a { color:var(--accent); }
  .docsContent h1,.docsContent h2,.docsContent h3,.docsContent h4 { color:var(--fg); }
  .docsContent pre { background:var(--code-bg); color:#e2e8f0; padding:16px 18px;
    border-radius:8px; overflow-x:auto; font:13px/1.55 ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; }
  .docsContent :not(pre) > code { background:var(--hover); padding:2px 5px;
    border-radius:4px; font-size:90%; }
  /* copy-to-clipboard button on code blocks (shown on hover) */
  .docsContent .codeWrap { position:relative; }
  .docsContent .copyBtn { position:absolute; top:8px; right:8px; opacity:0;
    background:rgba(148,163,184,.18); color:#e2e8f0; border:1px solid rgba(148,163,184,.32);
    border-radius:6px; padding:3px 10px; font-size:12px; cursor:pointer; transition:opacity .15s; }
  .docsContent .codeWrap:hover .copyBtn, .docsContent .copyBtn:focus-visible { opacity:1; }
  .docsContent .copyBtn:hover { background:rgba(148,163,184,.32); }
  .helpFooter { margin-top:3em; padding-top:1em; border-top:1px solid var(--border);
    font-size:.85em; color:var(--muted); }
  .helpFooter a { color:var(--muted); }
  @media (max-width:820px) {
    .docsLayout { flex-direction:column; }
    .docsSidebar { position:static; width:100%; height:auto;
      border-right:none; border-bottom:1px solid var(--border); }
    .docsContent { padding:16px; }
    .docsGh { display:none; }
  }
</style>
</head>
<body>
<header class="docsHeader">
  <a class="docsBrand" href="{{ prefix }}index.html">
    <img src="{{ prefix }}images/js9logo.png" alt="JS9"><span>JS9 Docs</span>
  </a>
  <pagefind-modal-trigger>
    <button class="searchBtn" type="button">Search the docs&hellip;</button>
  </pagefind-modal-trigger>
  <button id="themeToggle" class="iconBtn" type="button"
          aria-label="Toggle light/dark theme" title="Toggle light/dark theme">&#9681;</button>
  <a class="docsGh" href="{{ site.repo }}" target="_blank" rel="noopener">GitHub</a>
</header>
<div class="docsLayout">
  <nav class="docsSidebar" data-pagefind-ignore>
    {% for section in nav.sections %}
    <div class="docsSection">
      <div class="docsSectionTitle">{{ section.title }}</div>
      <ul>
        {% for item in section.items %}
        <li><a href="{{ prefix }}help/{{ item.slug }}.html"{% if item.slug == page.fileSlug %} class="active"{% endif %}>{{ item.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </nav>
  <main class="docsContent" data-pagefind-body>
    <article class="helpContainer">
{{ content }}
    </article>
    <footer class="helpFooter" data-pagefind-ignore>
      <p>
        {{ site.name }} {{ site.version }} &middot;
        <a href="{{ site.repo }}">GitHub</a> &middot;
        <a href="{{ site.homepage }}">Website</a> &middot;
        {{ site.license }} License
      </p>
      <p>
        Created and maintained through v3.9 by {{ site.originalAuthors }}
        ({{ site.originalOrg }}); maintained from v{{ site.handoverVersion }} by
        <a href="{{ site.maintainer.url }}">{{ site.maintainer.name }}</a>
        ({{ site.maintainer.org }}).
      </p>
    </footer>
  </main>
</div>

<!-- Pagefind Component UI: a search modal opened by the header trigger -->
<pagefind-modal>
  <pagefind-input></pagefind-input>
  <pagefind-results></pagefind-results>
</pagefind-modal>

<script src="{{ prefix }}vendor/highlight.js"></script>
<script src="{{ prefix }}pagefind/pagefind-component-ui.js"></script>
<script>
  (function(){
    var root = document.documentElement;
    var b = document.getElementById("themeToggle");
    function effective(){
      return root.getAttribute("data-theme") ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    }
    // keep the Pagefind search modal in sync with our theme (it only reads
    // [data-pf-theme="dark"] -- it does not follow prefers-color-scheme on its own)
    function syncPf(){
      if (effective() === "dark") root.setAttribute("data-pf-theme", "dark");
      else root.removeAttribute("data-pf-theme");
    }
    syncPf();
    if (b) b.addEventListener("click", function(){
      var next = effective() === "dark" ? "light" : "dark";
      root.setAttribute("data-theme", next);
      try { localStorage.setItem("js9-theme", next); } catch(e){}
      syncPf();
    });
    try {
      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", syncPf);
    } catch(e){}
  })();
</script>
</body>
</html>
