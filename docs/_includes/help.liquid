<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="{{ prefix }}js9.css">
<link rel="stylesheet" href="{{ prefix }}pagefind/pagefind-ui.css">
<title>{{ title }} &middot; JS9 Docs</title>
{% if head %}{{ head }}{% endif %}
<style>
  :root { --sidebar-w: 264px; --accent: #2b6cb0; --border: #e2e8f0; --muted: #718096; }
  * { box-sizing: border-box; }
  body { margin: 0; color: #1a202c;
    font: 15px/1.65 -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
  a { color: var(--accent); }
  .docsHeader { position: sticky; top: 0; z-index: 20; display: flex; align-items: center;
    gap: 16px; padding: 8px 16px; background: #fff; border-bottom: 1px solid var(--border); }
  .docsBrand { display: flex; align-items: center; gap: 8px; text-decoration: none;
    color: inherit; font-weight: 600; white-space: nowrap; }
  .docsBrand img { height: 26px; }
  .docsSearch { flex: 1; max-width: 460px; }
  .docsGh { margin-left: auto; text-decoration: none; color: var(--accent); font-size: 14px; }
  .docsLayout { display: flex; align-items: flex-start; }
  .docsSidebar { width: var(--sidebar-w); flex: 0 0 var(--sidebar-w);
    position: sticky; top: 44px; height: calc(100vh - 44px); overflow-y: auto;
    padding: 18px 14px; border-right: 1px solid var(--border); }
  .docsSection { margin-bottom: 18px; }
  .docsSectionTitle { font-size: 11px; text-transform: uppercase; letter-spacing: .06em;
    color: var(--muted); margin: 0 8px 6px; }
  .docsSidebar ul { list-style: none; margin: 0; padding: 0; }
  .docsSidebar li a { display: block; padding: 4px 8px; border-radius: 5px;
    text-decoration: none; color: #2d3748; font-size: 14px; }
  .docsSidebar li a:hover { background: #f7fafc; }
  .docsSidebar li a.active { background: #ebf4ff; color: var(--accent); font-weight: 600; }
  .docsContent { flex: 1 1 auto; min-width: 0; padding: 20px 36px 40px; max-width: 920px; }
  .helpFooter { margin-top: 3em; padding-top: 1em; border-top: 1px solid var(--border);
    font-size: .85em; color: var(--muted); }
  .helpFooter a { color: var(--muted); }
  @media (max-width: 820px) {
    .docsLayout { flex-direction: column; }
    .docsSidebar { position: static; width: 100%; height: auto;
      border-right: none; border-bottom: 1px solid var(--border); }
    .docsContent { padding: 16px; }
    .docsGh { display: none; }
  }
</style>
</head>
<body>
<header class="docsHeader">
  <a class="docsBrand" href="{{ prefix }}index.html">
    <img src="{{ prefix }}images/js9logo.png" alt="JS9"><span>JS9 Docs</span>
  </a>
  <div id="search" class="docsSearch"></div>
  <a class="docsGh" href="{{ site.repo }}" target="_blank" rel="noopener">GitHub</a>
</header>
<div class="docsLayout">
  <nav class="docsSidebar" data-pagefind-ignore>
    {% for section in nav.sections %}
    <div class="docsSection">
      <div class="docsSectionTitle">{{ section.title }}</div>
      <ul>
        {% for item in section.items %}
        <li><a href="{{ prefix }}help/{{ item.slug }}.html"{% if item.slug == page.fileSlug %} class="active"{% endif %}>{{ item.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </nav>
  <main class="docsContent" data-pagefind-body>
    <article class="helpContainer">
{{ content }}
    </article>
    <footer class="helpFooter" data-pagefind-ignore>
      <p>
        {{ site.name }} {{ site.version }} &middot;
        <a href="{{ site.repo }}">GitHub</a> &middot;
        <a href="{{ site.homepage }}">Website</a> &middot;
        {{ site.license }} License
      </p>
      <p>
        Created and maintained through v3.9 by {{ site.originalAuthors }}
        ({{ site.originalOrg }}); maintained from v{{ site.handoverVersion }} by
        <a href="{{ site.maintainer.url }}">{{ site.maintainer.name }}</a>
        ({{ site.maintainer.org }}).
      </p>
    </footer>
  </main>
</div>
<script src="{{ prefix }}pagefind/pagefind-ui.js"></script>
<script>
  window.addEventListener("DOMContentLoaded", function(){
    if( window.PagefindUI ){
      new PagefindUI({ element: "#search", showSubResults: true, showImages: false });
    }
  });
</script>
</body>
</html>
